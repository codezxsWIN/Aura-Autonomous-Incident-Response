# Optional language generation. Without a key, Aura uses deterministic local copy.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional LangSmith traces for the compiled LangGraph supervisor.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=aura-cogops-v2

# Docker-only local credentials. Change these outside a hackathon demo.
NEO4J_PASSWORD=aura-demo-password
MOCK_INFRA_API_KEY=aura-local-demo

# Presentation pacing only. Core resolution is measured independently.
AURA_DEMO_STEP_DELAY_MS=55