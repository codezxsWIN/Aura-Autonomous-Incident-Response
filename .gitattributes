# Normalize line endings on commit; check out native line endings.
* text=auto eol=lf

# Windows scripts keep CRLF
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Explicit text types
*.py text
*.js text
*.css text
*.html text
*.md text
*.yml text
*.yaml text
*.json text

# Binary assets (never diff or normalize)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
